# Copy this file to ~/.config/raycast-scripts/hue.env and fill in your values.
# The real hue.env is not tracked by chezmoi — credentials stay on your machine.
#
# See https://developers.meethue.com/develop/get-started-2/ for how to obtain
# a bridge IP and create an authorised username.

# Local IP address of your Hue bridge, e.g. 192.168.1.2
HUE_BRIDGE_IP=""

# Authorised username returned by the bridge
HUE_USERNAME=""

# Group/room ID for the office (not the scene — list groups with:
#   curl http://$HUE_BRIDGE_IP/api/$HUE_USERNAME/groups | jq 'to_entries[] | {id: .key, name: .value.name}'
# )
HUE_OFFICE_GROUP_ID=""
