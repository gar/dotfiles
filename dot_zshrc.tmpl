# ------------------------------
# History
# ------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY          # share history across sessions
setopt HIST_IGNORE_ALL_DUPS   # don't record duplicates
setopt HIST_REDUCE_BLANKS     # remove superfluous blanks
setopt HIST_VERIFY            # show expanded history before executing

# ------------------------------
# Shell options
# ------------------------------
setopt AUTO_CD           # cd by typing directory name
setopt CORRECT           # offer correction for mistyped commands
setopt INTERACTIVE_COMMENTS  # allow comments in interactive shell

# ------------------------------
# Editor
# ------------------------------
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# ------------------------------
# Aliases
# ------------------------------
alias vim="nvim"

# modern CLI replacements
alias grep='rg'
if command -v fdfind &>/dev/null; then
  alias find='fdfind'
elif command -v fd &>/dev/null; then
  alias find='fd'
fi

# git (subset of oh-my-zsh git plugin)
alias g="git"
alias ga="g add"
alias gaa="g add --all"
alias gap="g add -p"
alias gc="g commit -v"
alias gcm="g commit -m"
alias gco="g checkout"
alias gd="g diff"
alias gds="g diff --staged"
alias gl="g pull"
alias glog="g log --oneline --decorate --graph"
alias gp="g push"
alias gpu="g push -u origin HEAD"
alias grb="g rebase"
alias gst="g status"
alias gsw="g switch"
alias gswc="g switch -c"

# modern CLI tools
if command -v eza &>/dev/null; then
  alias ls='eza --icons'
  alias ll='eza -la --icons --git'
fi
if command -v bat &>/dev/null; then
  alias cat='bat'
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
elif command -v batcat &>/dev/null; then
  alias cat='batcat'
  export MANPAGER="sh -c 'col -bx | batcat -l man -p'"
fi
command -v broot &>/dev/null && alias tree='broot'
command -v hexyl &>/dev/null && alias xxd='hexyl'

# git worktree
alias gwl="g worktree list"
alias gwa="g worktree add"
alias gwd="g worktree remove"
alias gwp="g worktree prune"

# ------------------------------
# Environment
# ------------------------------
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
export ERL_AFLAGS="-kernel shell_history enabled"

# ------------------------------
# Plugins
# ------------------------------
# Plugins are sourced before compinit so their fpath entries are available.
{{- if eq .chezmoi.os "darwin" }}
source $(brew --prefix)/share/zsh-you-should-use/you-should-use.plugin.zsh
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh
{{- else }}
# Source plugins from standard Linux paths (apt: /usr/share, pacman: /usr/share/zsh/plugins)
for plugin_dir in /usr/share/zsh-you-should-use /usr/share/zsh/plugins/zsh-you-should-use; do
  [[ -f "$plugin_dir/you-should-use.plugin.zsh" ]] && source "$plugin_dir/you-should-use.plugin.zsh" && break
done
for plugin_dir in /usr/share/zsh-autosuggestions /usr/share/zsh/plugins/zsh-autosuggestions; do
  [[ -f "$plugin_dir/zsh-autosuggestions.zsh" ]] && source "$plugin_dir/zsh-autosuggestions.zsh" && break
done
for plugin_dir in /usr/share/zsh/plugins/fast-syntax-highlighting /usr/share/fast-syntax-highlighting; do
  [[ -f "$plugin_dir/fast-syntax-highlighting.plugin.zsh" ]] && source "$plugin_dir/fast-syntax-highlighting.plugin.zsh" && break
done
{{- end }}

# ------------------------------
# Completion
# ------------------------------
autoload -Uz compinit
# -i: silently ignore insecure files/dirs (e.g. group-writable Homebrew paths)
compinit -i

zstyle ':completion:*' menu select                     # interactive menu
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'   # case-insensitive match
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}" # coloured completions

# ------------------------------
# Prompt (robbyrussell-style)
# ------------------------------
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats ' %F{red}(%b)%f'
setopt PROMPT_SUBST
PROMPT='%(?:%F{green}➜:%F{red}➜)%f %F{cyan}%c%f${vcs_info_msg_0_} '

# ------------------------------
# Tool integrations
# ------------------------------
eval "$(mise activate zsh)"
eval "$(direnv hook zsh)"
eval "$(zoxide init zsh)"
command -v fzf &>/dev/null && eval "$(fzf --zsh)"
eval "$(chezmoi completion zsh)"
command -v op &>/dev/null && eval "$(op completion zsh)" && compdef _op op
# broot shell integration — provides the 'br' function (run 'broot --install' once to enable)
[[ -f "$HOME/.config/broot/launcher/bash/1" ]] && source "$HOME/.config/broot/launcher/bash/1"

# ------------------------------
# zsh-autosuggestions
# ------------------------------
# Bound here (after all evals) so nothing overrides it; $'\x00' is the NUL byte
# that terminals send for Ctrl+Space, which is more reliable than '^ '
bindkey '^O' autosuggest-accept   # ctrl+o ("okay") to accept suggestion

# ------------------------------
# Local overrides (device-specific, not checked in)
# ------------------------------
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
